# SurveyMind Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM / AI Providers ──────────────────────────────────────────────────────────

# OpenAI-compatible API (DeepSeek, Kimi, Grok, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# OpenRouter (gateway to multiple providers)
OPENROUTER_API_KEY=

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.5

# Google Gemini
GEMINI_API_KEY=

# Anthropic (Claude via OpenRouter)
ANTHROPIC_AUTH_TOKEN=sk-or-v1-...
ANTHROPIC_BASE_URL=https://openrouter.ai/api

# ── arXiv ──────────────────────────────────────────────────────────────────────

# Optional: arXiv API key for higher rate limits
# https://info.arxiv.org/help/api/key.html
ARXIV_API_KEY=

# ── SurveyMind MCP Servers ─────────────────────────────────────────────────────

# Used by mcp-servers/llm-chat/server.py
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_SERVER_NAME=llm-chat

# Used by mcp-servers/minimax-chat/server.py
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.5

# ── Notifications ───────────────────────────────────────────────────────────────

# Feishu/Lark webhook for pipeline notifications
FEISHU_WEBHOOK_URL=

# ── Reproduction Pipeline ─────────────────────────────────────────────────────

# GitHub personal access token (optional, avoids API rate limits)
GITHUB_TOKEN=

# Max repos to discover/clone/reproduce per run
REPRODUCTION_MAX_REPOS=10

# Per-repo clone timeout in seconds
REPRODUCTION_TIMEOUT=120

# Custom reproduction output directory (default: surveys/survey_<topic>/gate7_reproduction)
# REPRODUCTION_DIR=

# ── Algorithm R&D Pipeline ────────────────────────────────────────────────────

# Root directory for algorithm experiments (default: experiments/)
# ALGO_EXPERIMENTS_DIR=experiments

# Max training time per run in seconds (default: 3600 = 1 hour)
ALGO_TRAINING_TIMEOUT=3600

# Max reflect-retrain iterations (default: 3)
ALGO_MAX_REFLECT_ITERATIONS=3

# CPU thread limit for training (OMP / MKL)
ALGO_CPU_THREADS=4

# Default device for new tasks (cpu / gpu / mps)
ALGO_DEFAULT_DEVICE=cpu

# Default domain profile for new tasks
ALGO_DEFAULT_DOMAIN=wifi_csi_har

# ── Dashboard ─────────────────────────────────────────────────────────────────

# Gradio dashboard port
DASHBOARD_PORT=7860

# Auto-start dashboard after pipeline completion (true / false)
DASHBOARD_AUTO_START=false

# ── Paths ──────────────────────────────────────────────────────────────────────

# Root directory of the SurveyMind project (default: auto-detected)
# SURVEYMIND_ROOT=/path/to/SurveyMind
